@using Sporta.Data.ViewModels; 
@model LoginVM;

@{ 
    ViewData["Title"] = "Log In";
}

<section class="d-flex flex-row p-0" style="height: 700px">
    <div class="d-flex flex-column justify-content-end container-fluid flex-grow-1 bg-secondary p-5 bg-img">
        <p class="fs-2 fw-bolder text-white m-0">Members only:</p>
        <p class="fw-bolder text-uppercase text-white m-0" style="font-size: 5rem; line-height: 0.8;">
            get <span class="text-danger">10%</span><br />
            discount<br />
            of your 1st<br />
            purchase.<br />
        </p>
    </div>
    <div class="d-flex container-fluid p-5">
        <form asp-action="Login" class="d-flex flex-column flex-grow-1 justify-content-between">
            <div>
                <div class="mb-4">
                    <p class="fs-2 fw-bold m-0">Log In</p>
                    <p class="m-0">
                        Don't have an account?
                        <a asp-controller="Account" asp-action="Register" class="text-reset text-decoration-none fw-bold">Sign Up</a>
                    </p>
                </div>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group position-relative mb-3">
                    <span class="position-absolute translate-middle" style="top: 33px; left: 29px;">
                        <span class="material-icons-outlined">email</span>
                    </span>
                    <input asp-for="EmailAddress" placeholder="Email Address" class="form-control fw-semibold border-2 border-black rounded-4 ps-5 py-3" />
                    <span asp-validation-for="EmailAddress" class="text-danger mt-2"></span>
                </div>
                <div class="form-group position-relative">
                    <span class="position-absolute translate-middle" style="top: 33px; left: 29px;">
                        <span class="material-icons-outlined">lock</span>
                    </span>
                    <input asp-for="Password" placeholder="Password" class="form-control fw-semibold border-2 border-black rounded-4 ps-5 py-3" />
                    <span asp-validation-for="Password" class="text-danger mt-2"></span>
                </div>
            </div>
            <div class="form-group">
                <input class="btn container-fluid rounded-4 bg-black text-white py-3 fw-bold" type="submit" value="Log In" />
            </div>
        </form>
    </div>
</section>