@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "List of All Users";
}

<section class="align-items-center">
    <div class="p-5 w-50">
        <p class="fs-4 fw-bold text-center m-0 mb-4">All Users</p>
        <table class="table">
            <thead>
                <tr>
                    <th scope="col" class="table-dark">@Html.DisplayNameFor(model => model.FullName)</th>
                    <th scope="col" class="table-dark">@Html.DisplayNameFor(model => model.UserName)</th>
                    <th scope="col" class="table-dark">@Html.DisplayNameFor(model => model.Email)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.FullName)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.UserName)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Email)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>