@model Product

@{
    ViewData["Title"] = @Model.Name;
}

<section>
    <div class="row m-0 p-5">
        <div class="col p-0">
            <p class="fs-4 fw-bold m-0">Select Size</p>
            <div class="row row-cols-5 gy-3 text-center m-0">
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 6</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 6.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 7</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 7.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 8</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 8.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 9</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 9.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 10</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 10.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 11</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 11.5</a>
                <a class="col btn btn-outline-dark fw-bold border-2 rounded-4 p-2 me-3" role="Button" style="font-size: 0.9rem">UK 12</a>
            </div>
        </div>
        <div class="col-5 mx-4 pe-3 p-0">
            <div class="d-flex overflow-hidden bg-secondary-subtle mb-3 p-0" style="height: 500px">
                <img src="@Model.Picture1" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
            </div>
            <div class="container-fluid overflow-hidden p-0">
                <div class="row mb-3">
                    <div class="col d-flex overflow-hidden bg-secondary-subtle me-3 p-0" style="height: 400px">
                        <img src="@Model.Picture2" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
                    </div>
                    <div class="col d-flex overflow-hidden bg-secondary-subtle p-0" style="height: 400px">
                        <img src="@Model.Picture3" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col d-flex overflow-hidden bg-secondary-subtle me-3 p-0" style="height: 400px">
                        <img src="@Model.Picture4" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
                    </div>
                    <div class="col d-flex overflow-hidden bg-secondary-subtle p-0" style="height: 400px">
                        <img src="@Model.Picture5" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
                    </div>
                </div>
                <div class="row">
                    <div class="col d-flex overflow-hidden bg-secondary-subtle me-3 p-0" style="height: 400px">
                        <img src="@Model.Picture6" class="flex-grow-1" style="object-fit: cover" alt="@Model.Name" />
                    </div>
                    <div class="col p-0"></div>
                </div>
            </div>
        </div>
        <div class="col p-0">
            <div>
                <p class="fs-4 fw-bold m-0">@Model.Name</p>
                <p class="m-0">Men's @Model.ProductCategory Shoes</p>
            </div>
            <p class="fs-2 fw-bold m-0 my-3">RM<span>@Model.Price</span></p>
            <p class="m-0 pe-5 mb-4">Let the Nike Pegasus FlyEase, a balanced and energised ride for any run, help you ascend to new heights. A supportive sensation helps keep your foot contained, while underfoot Air adds a pop to your step as you transition from heel to toe. Nike FlyEase technology acts as a strap, helping secure the fit. Your trusted workhorse with wings is back. Time to fly.</p>
            <div class="m-0 pe-5 mb-4">
                <ul>
                    <li>Color Shown: @Model.Color</li>
                    <li>Style: @Model.Style</li>
                </ul>
            </div>
            <div class="d-flex justify-content-between">
                <a asp-controller="Orders"
                   asp-action="AddItemToShoppingCart" 
                   asp-route-id="@Model.Id"
                   class="btn fw-semibold bg-black text-white rounded-4 py-2" 
                   role="Button" 
                   style="width: 180px; font-size: 0.9rem">Add To Cart</a>
                @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a asp-controller="Products" 
                       asp-action="Edit" 
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-dark border-2 rounded-4 fw-semibold py-2"
                       role="Button"
                       style="width: 180px; font-size: 0.9rem">Update Products</a>
                }
            </div>
        </div>
    </div>
</section>