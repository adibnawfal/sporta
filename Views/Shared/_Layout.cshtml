<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Sporta</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Material+Icons|Material+Icons+Outlined|Material+Icons+Two+Tone|Material+Icons+Round|Material+Icons+Sharp" rel="stylesheet">
</head>
<body>
    <div class="row align-items-center m-0 py-3 px-5">
        <div class="col p-0">
            <a class="fs-4 fw-bold text-reset text-decoration-none" href="Home">Sporta.</a>
        </div>
        <div class="col-md-auto">
            <a asp-controller="Home" asp-action="Index" class="fw-bold text-reset text-decoration-none text-center" style="width: 100px">Home</a>
            <a asp-controller="Products" asp-action="Index" class="fw-bold text-reset text-decoration-none text-center mx-5" style="width: 100px">Products</a>
            <a href="#" class="fw-bold text-reset text-decoration-none text-center" style="width: 100px">SALE</a>
        </div>
        <div class="col d-flex justify-content-end align-items-center p-0">

            <ul class="navbar-nav">
                @await Component.InvokeAsync("ShoppingCartSummary")
            </ul>

            <partial name="_Identity.cshtml" />
        </div>
    </div>

    @RenderBody()

    <footer class="bg-black m-0 p-0 px-5">
        <div class="container-fluid p-0 mt-5">
            <div class="d-flex justify-content-between mb-5">
                <div>
                    <p class="fs-4 fw-bold text-white">Sporta.</p>
                </div>
                <div>
                    <p class="fw-bold text-secondary m-0 mb-2">Product</p>
                    <ul class="list-unstyled text-white" style="font-size: 0.9rem">
                        <li>Lifestyle</li>
                        <li>Running</li>
                        <li>Basketball</li>
                        <li>Footbal</li>
                        <li>Training & Gym</li>
                    </ul>
                </div>
                <div>
                    <p class="fw-bold text-secondary m-0 mb-2">Support</p>
                    <ul class="list-unstyled text-white" style="font-size: 0.9rem">
                        <li>FAQ</li>
                        <li>Delivery</li>
                        <li>Returns</li>
                        <li>Payment Options</li>
                        <li>Contact Us</li>
                    </ul>
                </div>
                <div>
                    <p class="fw-bold text-secondary m-0 mb-2">About Us</p>
                    <ul class="list-unstyled text-white" style="font-size: 0.9rem">
                        <li>News</li>
                        <li>Careers</li>
                        <li>Investors</li>
                        <li>Sustainability</li>
                    </ul>
                </div>
                <div class="d-flex flex-column">
                    <p class="fw-bold text-secondary m-0 mb-2">Follow us</p>
                    <div class="ms-auto text-white">
                        <a class="text-reset"><i class="fa-brands fa-facebook fa-lg ms-2"></i></a>
                        <a class="text-reset"><i class="fa-brands fa-tiktok fa-lg ms-2"></i></a>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-between pb-4">
                <p class="fw-bold text-secondary m-0" style="font-size: 0.9rem">
                    Copyright © 2023 Sporta. All Rights Reserved
                </p>
                <p class="fw-bold text-secondary m-0" style="font-size: 0.9rem">
                    Privacy Policy
                </p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="https://kit.fontawesome.com/b1f9711591.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>